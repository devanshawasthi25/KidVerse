# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose "claude" or "openai"
AI_PROVIDER=claude

# Add your key for the chosen provider (leave the other blank)
CLAUDE_API_KEY=your-claude-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – no setup needed):
DATABASE_URL=sqlite:///./kidverse.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost/kidverse

# ── Email OTP (SMTP) ─────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for JWT tokens (change this in production!)
JWT_SECRET=kidverse-super-secret-key-change-me
